# ---- Project runtime state ----
# state/ is auto-created at startup (backend/config.py); keep the dir,
# ignore the runtime logs and any local databases written into it.
state/*.log
state/*.db
state/*.sqlite
state/*.sqlite3
!state/.gitkeep
